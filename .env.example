# ── Swasthya-Neeti — Environment Variables ──
# Copy this file to .env and fill in your values.

# MongoDB connection string (MongoDB Atlas cloud)
MONGO_URI="mongodb+srv://USER:PASSWORD@HOST/DATABASE_NAME?retryWrites=true&w=majority"

# Groq API key and model
GROQ_API_KEY="your_groq_api_key_here"
GROQ_MODEL="llama-3.1-8b-instant"

# Server port (local development only — ignored on Vercel)
PORT=3001

# Frontend API base URL (leave empty for Vercel — only needed for custom setups)
# VITE_API_BASE_URL="http://localhost:3001"
